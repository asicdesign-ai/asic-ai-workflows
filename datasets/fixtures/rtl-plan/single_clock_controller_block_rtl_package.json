  "requirements": [
    {
      "id": "REQ-001",
      "title": "count ticks while busy",
      "category": "function",
      "priority": "must",
      "source": "user",
      "description": "The controller counts tick_i events while busy_o is high.",
      "acceptance_criteria": "With busy_o high, each asserted tick_i increments the internal count toward threshold_i."
    },
    {
      "id": "REQ-002",
      "title": "clear state on reset",
      "category": "clock_reset",
      "priority": "must",
      "source": "user",
      "description": "Reset returns the controller to idle state with zero count and no done pulse.",
      "acceptance_criteria": "After reset, busy_o and done_o are low and count_q is zero."
    },
    {
      "id": "REQ-003",
      "title": "pulse done on threshold match",
      "category": "function",
      "priority": "must",
      "source": "user",
      "description": "The controller emits a one-cycle done pulse when the terminal count is reached.",
      "acceptance_criteria": "done_o pulses high for one cycle when count_q reaches threshold_i and busy_o deasserts."
    }
  ],
