    "source_files",
    "rtl_modules",
    "traceability",
    "unresolved",
    "summary"
  ],
  "properties": {
    "design": {
      "type": "object"
    },
    "source_files": {
      "type": "array"
    },
    "rtl_modules": {
      "type": "array"
    },
    "traceability": {
      "type": "array"
    },
    "unresolved": {
      "type": "array"
    },
    "summary": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
