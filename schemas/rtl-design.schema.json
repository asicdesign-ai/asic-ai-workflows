{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RTL Design Report",
  "type": "object",
  "required": [
    "design",
    "source_files",
    "rtl_modules",
    "traceability",
    "unresolved",
    "tool_evidence",
    "summary"
  ],
  "properties": {
    "design": {
      "type": "object"
    },
    "source_files": {
      "type": "array"
    },
    "rtl_modules": {
      "type": "array"
    },
    "traceability": {
      "type": "array"
    },
    "unresolved": {
      "type": "array"
    },
    "tool_evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/toolEvidence"
      }
    },
    "summary": {
      "type": "object"
    }
  },
  "$defs": {
    "toolEvidence": {
      "type": "object",
      "required": [
        "source",
        "tools",
        "purpose",
        "status",
        "summary"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "purpose": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "used",
            "unavailable",
            "incomplete",
            "error"
          ]
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
